@section scripts{
    <script src="@Url.Content("~/Scripts/Views/Venta_Crear.js")?v=@DateTime.Now.Ticks" type="text/javascript"></script>

    <script>

        // =========================================
        // RECALCULAR VENTA
        // =========================================

        function recalcularVenta() {

            let total = 0;

            $("#tbVenta tbody tr").each(function () {

                let fila = $(this);

                let importeTexto = fila
                    .find(".importetotal")
                    .text()
                    .trim();

                importeTexto = importeTexto
                    .replace("S/", "")
                    .replace(",", "");

                let importe =
                    parseFloat(importeTexto) || 0;

                total += importe;

            });

            // ============================
            // DESCUENTO
            // ============================

            let porcDesc =
                parseFloat($("#txtdescuentoporcentaje").val()) || 0;

            let montoDesc =
                (total * porcDesc) / 100;

            let base =
                total - montoDesc;

            // ============================
            // IGV (18%)
            // ============================

            let subtotal = base / 1.18;

            let igv = base - subtotal;

            let totalFinal = base;

            // ============================
            // SET VALORES
            // ============================

            $("#txtsubtotal").val(subtotal.toFixed(2));
            $("#txtigv").val(igv.toFixed(2));
            $("#txttotal").val(totalFinal.toFixed(2));
            $("#txtdescuentomonto").val(montoDesc.toFixed(2));

            recalcularCambio();
        }

        // =========================================
        // RECALCULAR CAMBIO
        // =========================================

        function recalcularCambio() {

            let total =
                parseFloat(
                    $("#txttotal").val()
                ) || 0;

            let montoPago =
                parseFloat(
                    $("#txtmontopago").val()
                ) || 0;

            let cambio =
                montoPago - total;

            $("#txtcambio").val(

                cambio >= 0
                    ? cambio.toFixed(2)
                    : "0.00"

            );
        }

        // =========================================
        // MONTO PAGO
        // =========================================

        $(document).on(
            "keyup change",
            "#txtmontopago",
            function () {

                recalcularCambio();

            });

        // =========================================
        // BOTON CALCULAR
        // =========================================

        $(document).on(
            "click",
            "#btncalcular",
            function () {

                recalcularCambio();

            });

        // =========================================
        // ELIMINAR PRODUCTO
        // =========================================

        $(document).on(
            "click",
            ".btn-eliminar",
            function () {

                $(this)
                    .closest("tr")
                    .remove();

                recalcularVenta();

            });

        // =========================================
        // CAMBIAR CANTIDAD
        // =========================================

        $(document).on(
            "input",
            ".txtcantidad",
            function () {

                let fila =
                    $(this).closest("tr");

                let cantidad =
                    parseFloat(
                        $(this).val()
                    ) || 0;

                // =========================
                // OBTENER PRECIO
                // =========================

                let precioTexto =
                    fila.find(".precio-unitario")
                        .text()
                        .trim();

                precioTexto = precioTexto
                    .replace("S/", "")
                    .replace(",", "");

                let precio =
                    parseFloat(precioTexto) || 0;

                // =========================
                // NUEVO IMPORTE
                // =========================

                let nuevoImporte =
                    cantidad * precio;

                fila.find(".importetotal")
                    .text(
                        nuevoImporte.toFixed(2)
                    );

                recalcularVenta();

            });

        // =========================================
        // AGREGAR PRODUCTO
        // =========================================

        $(document).on(
            "click",
            "#btnAgregar",
            function () {

                // Esperar JS original

                setTimeout(function () {

                    recalcularVenta();

                }, 200);

            });

        // =========================================
        // AGREGAR porcentaje
        // =========================================

        $(document).on(
            "input",
            "#txtdescuentoporcentaje",
            function () {

                recalcularVenta();

            }
        );

        // =========================================
        // INICIAL
        // =========================================

        $(document).ready(function () {

            recalcularVenta();

        });

    </script>
}