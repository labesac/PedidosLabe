
@{
    ViewBag.Title = "Crear";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .tarjeta-direccion {
        transition: .2s;
        border-radius: 12px;
        background: #fff;
    }

        .tarjeta-direccion:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 14px rgba(0,0,0,.08);
        }

        .tarjeta-direccion .card-body {
            font-size: 13px;
        }
</style>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="#">Clientes</a></li>
        <li class="breadcrumb-item active" aria-current="page">Registrar</li>
    </ol>
</nav>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-header bg-secondary text-white">
                Lista de Clientes
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-sm-4">
                        <button type="button" class="btn btn-sm btn-success" onclick="abrirPopUpForm(null)"> <i class="fa fa-plus" aria-hidden="true"></i> Agregar Nuevo</button>
                    </div>
                </div>
                <hr />
                <div class="row mt-3">
                    <div class="col-sm-12">
                        @*<table id="tbdata" class="table table-striped table-bordered nowrap compact" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Tipo Documento</th>
                                    <th>Numero Documento</th>
                                    <th>Nombres</th>
                                    <th>Direccion</th>
                                    <th>Telefono</th>
                                    <th>Estado</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>*@

                        <table id="tbdata" class="table table-borderless w-100">
                            <thead>
                                <tr>
                                    <th>Clientes</th>
                                </tr>
                            </thead>
                        </table>

                    </div>
                </div>
            </div>
            <div class="card-footer">
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade"
     id="FormModal"
     tabindex="-1"
     role="dialog"
     data-backdrop="static"
     aria-hidden="true">

    <div class="modal-dialog modal-md" role="document">

        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header bg-secondary text-white">

                <h5 class="modal-title">
                    Cliente
                </h5>

                <button type="button"
                        class="close text-white"
                        data-dismiss="modal">

                    <span>&times;</span>

                </button>

            </div>

            <!-- BODY -->
            <div class="modal-body">

                <form id="form">

                    <input id="txtid"
                           class="model"
                           value="0"
                           type="hidden" />

                    <!-- ===================================== -->
                    <!-- BOTONES SECCIONES -->
                    <!-- ===================================== -->
                    <div class="text-center mb-3">

                        <div class="btn-group btn-group-sm w-100">

                            <button type="button"
                                    class="btn btn-secondary active"
                                    id="btnSeccionCliente">

                                <i class="fa fa-user"></i>
                                Cliente

                            </button>

                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    id="btnSeccionDireccion">

                                <i class="fa fa-map-marker-alt"></i>
                                Direcciones

                            </button>

                        </div>

                    </div>

                    <!-- ===================================== -->
                    <!-- SECCION CLIENTE -->
                    <!-- ===================================== -->
                    <div id="seccionCliente">

                        <!-- TIPO DOCUMENTO -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Tipo Documento
                            </label>

                            <div class="col-sm-10">

                                <select class="form-control form-control-sm model"
                                        id="cboclientetipodocumento">

                                    <option value="DNI">DNI</option>
                                    <option value="RUC">RUC</option>

                                </select>

                            </div>

                        </div>

                        <!-- NUMERO DOCUMENTO -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Numero Documento
                            </label>

                            <div class="col-sm-10">

                                <div class="input-group input-group-sm">

                                    <input type="text"
                                           class="form-control required"
                                           id="txtNumeroDocumento"
                                           name="numerodocumento"
                                           placeholder="Ingrese documento"
                                           maxlength="11">

                                    <div class="input-group-append">

                                        <button class="btn btn-primary"
                                                type="button"
                                                id="btnBuscarDNI">

                                            <i class="fas fa-search"></i>

                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- NOMBRES -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Nombres
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm required"
                                       id="txtNombres"
                                       name="nombres">

                            </div>

                        </div>

                        <!-- DIRECCION -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Dirección
                            </label>

                            <div class="col-sm-10">

                                <div class="input-group input-group-sm">

                                    <input type="text"
                                           class="form-control required"
                                           id="txtDireccion"
                                           name="direccion">

                                    <div class="input-group-append">

                                        <button class="btn btn-primary"
                                                type="button"
                                                id="btnAgregaDireccion">

                                            <i class="fas fa-plus-circle mr-1"></i>

                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- TELEFONO -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Teléfono
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm required"
                                       id="txtTelefono"
                                       name="telefono">

                            </div>

                        </div>

                        <!-- EMAIL -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Email
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="txtEmail"
                                       name="email">

                            </div>

                        </div>

                        <!-- UBICACION -->
                        <div class="row mb-3">

                            <div class="col-12">

                                <button type="button"
                                        class="btn btn-light btn-sm mb-2"
                                        id="btnUbicacionActual">

                                    <i class="fa fa-map-marker-alt"></i>
                                    Mi ubicación

                                </button>

                                <div class="card border-0 shadow-sm">

                                    <div class="card-body p-2">

                                        <div id="mapa"
                                             style="height:300px;width:100%;border-radius:10px;">
                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                        <!-- ESTADO -->
                        <div class="form-group row">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Activo
                            </label>

                            <div class="col-sm-10">

                                <select class="form-control form-control-sm model"
                                        id="cboEstado"
                                        name="Activo">

                                    <option value="1">Activo</option>
                                    <option value="0">No Activo</option>

                                </select>

                            </div>

                        </div>

                    </div>

                    <!-- ===================================== -->
                    <!-- SECCION DIRECCIONES -->
                    <!-- ===================================== -->
                    <div id="seccionDirecciones" style="display:none;">

                        <!-- NOMBRE -->
                        <div class="form-group row d-none">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Nombre
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="txtNombreDireccion"
                                       placeholder="Principal">

                            </div>

                        </div>

                        <!-- DIRECCION -->
                        <div class="form-group row d-none">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Dirección
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="txtDireccionEntrega">

                            </div>

                        </div>

                        <!-- ENCARGADO -->
                        <div class="form-group row d-none">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Encargado
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="txtEncargado">

                            </div>

                        </div>

                        <!-- TELEFONO -->
                        <div class="form-group row d-none">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Teléfono
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="txtTelefonoEntrega">

                            </div>

                        </div>

                        <!-- EMAIL -->
                        <div class="form-group row d-none">

                            <label class="col-sm-2 col-form-label col-form-label-sm">
                                Email
                            </label>

                            <div class="col-sm-10">

                                <input type="text"
                                       class="form-control form-control-sm"
                                       id="txtEmailEncargado">

                            </div>

                        </div>

                        <!-- TABLA DIRECCIONES -->
                        <div id="contenedorDirecciones" class="row"></div>

                    </div>
                </form>
            </div>

            <!-- FOOTER -->
            <div class="modal-footer">

                <button type="button"
                        class="btn btn-sm btn-danger"
                        data-dismiss="modal">

                    Cerrar
                </button>

                <button id="btnGuardarCambios"
                        type="button"
                        class="btn btn-sm btn-primary"
                        onclick="Guardar()">

                    Guardar
                </button>

            </div>

        </div>

    </div>

</div>

<!-- Modal direcciones -->
<div class="modal fade" id="modalDireccion" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg rounded-lg">

            <!-- HEADER -->
            <div class="modal-header bg-primary text-white py-2">
                <h5 class="modal-title">
                    <i class="fas fa-map-marker-alt mr-2"></i>
                    Nueva Dirección
                </h5>

                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <input type="hidden" id="txtIdClienteDireccion" value="0" />
                <input type="hidden" id="txtIdCliente" />

                <div class="row">

                    <!-- NOMBRE -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Nombre</label>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   id="txt_NombreDireccion"
                                   placeholder="Principal / Casa / Oficina">
                        </div>
                    </div>

                    <!-- TELEFONO -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Teléfono</label>
                            <input type="text"
                                   class="form-control form-control-sm"
                                   id="txt_TelefonoDireccion"
                                   placeholder="999000111">
                        </div>
                    </div>

                    <!-- PRINCIPAL -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Dirección Principal</label>

                            <div class="custom-control custom-switch mt-1">
                                <input type="checkbox"
                                       class="custom-control-input"
                                       id="chk_EsPrincipal">

                                <label class="custom-control-label"
                                       for="chk_EsPrincipal">
                                    Sí
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- DIRECCION -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Dirección</label>

                            <textarea class="form-control form-control-sm"
                                      id="txt_Direccion"
                                      rows="2"
                                      placeholder="Ingrese dirección completa"></textarea>
                        </div>
                    </div>

                    <!-- GEOLOCALIZACION -->
                    <div class="col-md-12">

                        <div class="d-flex justify-content-between align-items-center mb-2">

                            <label class="mb-0">
                                Ubicación
                            </label>

                            <button type="button"
                                    class="btn btn-sm btn-outline-primary"
                                    id="btnUbicacionDireccion">

                                <i class="fas fa-location-arrow mr-1"></i>
                                Mi ubicación

                            </button>

                        </div>

                        <div class="card border-0 shadow-sm">
                            <div class="card-body p-2">

                                <div id="mapaDireccion"
                                     style="height:250px;border-radius:10px;">
                                </div>

                            </div>
                        </div>

                    </div>

                    <!-- ENCARGADO -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Encargado</label>

                            <input type="text"
                                   class="form-control form-control-sm"
                                   id="txt_Encargado"
                                   placeholder="Nombre encargado">
                        </div>
                    </div>

                    <!-- EMAIL -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Email Encargado</label>

                            <input type="email"
                                   class="form-control form-control-sm"
                                   id="txt_EmailEncargado"
                                   placeholder="correo@gmail.com">
                        </div>
                    </div>

                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer py-2">

                <button type="button"
                        class="btn btn-light border"
                        data-dismiss="modal">

                    <i class="fas fa-times mr-1"></i>
                    Cancelar
                </button>

                <button type="button"
                        class="btn btn-primary"
                        id="btnGuardarDireccion">

                    <i class="fas fa-save mr-1"></i>
                    Guardar
                </button>

            </div>

        </div>
    </div>
</div>

@section scripts{
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="@Url.Content("~/Scripts/Views/Cliente_Crear.js")" type="text/javascript"></script>

    <script>

        $("#btnBuscarDNI").on("click", function () {

            let tipoDocumento = $("#cboclientetipodocumento").val();
            let numero = $("#txtNumeroDocumento").val().trim();

            if (tipoDocumento == "DNI") {

                if (numero.length != 8) {
                    alert("Ingrese un DNI válido");
                    return;
                }

                buscarDNI(numero);

            } else if (tipoDocumento == "RUC") {

                if (numero.length != 11) {
                    alert("Ingrese un RUC válido");
                    return;
                }

                buscarRUC(numero);
            }

        });

        function buscarDNI(dni) {

            dni = dni.trim();

            // Validar DNI
            if (dni.length !== 8 || isNaN(dni)) {
                alert("Ingrese un DNI válido");
                return;
            }

            $("#btnBuscarDNI").prop("disabled", true);

            $.ajax({
                url: $.MisUrls.url._ConsultarDNI,
                type: 'GET',
                data: { dni: dni },
                dataType: 'json',

                success: function (response) {

                    console.log(response);

                    if (response.success) {

                        $("#txtNombres").val(response.data.nombres_completos || "");
                        $("#txtDireccion").val(response.data.diseccion || "");

                    } else {

                        alert(response.mensaje || "DNI no encontrado");
                    }
                },

                error: function () {

                    alert("No se pudo consultar el DNI");
                },

                complete: function () {

                    $("#btnBuscarDNI").prop("disabled", false);
                }
            });
        }

        function buscarRUC(ruc) {

            $("#btnBuscarDNI").prop("disabled", true);

            $.ajax({
                url: $.MisUrls.url._ConsultarRuc,
                type: 'GET',
                data: { ruc: ruc },
                dataType: 'json',

                success: function (response) {

                    console.log(response);

                    if (response.success) {

                        $("#txtNombres").val(response.razonSocial);
                        $("#txtDireccion").val(response.direccion);

                    } else {

                        alert(response.mensaje || "RUC no encontrado");
                    }
                },

                error: function () {
                    alert("No se pudo consultar el RUC");
                },

                complete: function () {
                    $("#btnBuscarDNI").prop("disabled", false);
                }
            });
        }

        $("#cboclientetipodocumento").change(function () {

            let tipo = $(this).val();

            if (tipo == "DNI") {
                $("#txtNumeroDocumento")
                    .attr("maxlength", "8")
                    .attr("placeholder", "Ingrese DNI");
            }
            else {

                $("#txtNumeroDocumento")
                    .attr("maxlength", "11")
                    .attr("placeholder", "Ingrese RUC");
            }

            $("#txtNumeroDocumento").val("");
        });

    </script>

}

