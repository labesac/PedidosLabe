    <!-- =========================================
         MENU
    ==========================================-->

    <script>

        $(document).ready(function () {

            // ===== ABRIR / CERRAR SUBMENU =====

            $('.nav-item.dropdown > a').on('click', function (e) {

                e.preventDefault();
                e.stopPropagation();

                let parent = $(this).parent();
                let submenu = parent.find('.dropdown-menu').first();

                // cerrar otros
                $('.nav-item.dropdown').not(parent)
                    .removeClass('open')
                    .find('.dropdown-menu')
                    .slideUp(200);

                // toggle actual
                if (submenu.is(':visible')) {

                    submenu.slideUp(200);
                    parent.removeClass('open');

                } else {

                    submenu.slideDown(200);
                    parent.addClass('open');

                }

            });


            // ===== MOSTRAR / OCULTAR SIDEBAR =====

            //$("#btnToggleSidebar").click(function () {

            //    $(".sidebar").toggleClass("sidebar-hide");
            //    $(".topbar").toggleClass("topbar-full");
            //    $(".main-content").toggleClass("content-full");

            //});

            $("#btnToggleSidebar").click(function () {

                // MOBILE
                if ($(window).width() <= 768) {

                    $(".sidebar").toggleClass("sidebar-show");

                }
                // DESKTOP
                else {

                    $(".sidebar").toggleClass("sidebar-hide");
                    $(".topbar").toggleClass("topbar-full");
                    $(".main-content").toggleClass("content-full");

                }

            });

        });


        // ===== ACTIVAR MENU =====

        function activarMenu(menuactivo) {

            var ul = $("ul.navbar-nav");

            ul.find("li.nav-item").each(function (i, li) {

                $(li).removeClass("active");

                if ($(li).find("div.dropdown-menu").length != 0) {

                    var div = $(li).find("div.dropdown-menu");

                    div.find("a.dropdown-item").each(function (x, tagA) {

                        if ($(tagA).attr("name") == menuactivo) {

                            $(li).addClass("active");
                            $(div).show();

                            return false;
                        }

                    });

                } else {

                    var a = $(li).find("a.nav-link");

                    if ($(a).attr("name") == menuactivo) {

                        $(li).addClass("active");

                        return false;
                    }
                }

            });
        }

    </script>

     <!-- =========================================
         SESION
    ==========================================-->
     <script>

        $(document).ajaxComplete(function (event, xhr, settings) {

            try {

                // intentar convertir respuesta
                var response = JSON.parse(xhr.responseText);

                // sesión vencida
                if (response.sesionExpirada) {

                    alert("La sesión ha expirado");

                    window.location.href = '/Login/Index';

                }

            } catch (e) {

                // no era json válido
            }

        });

    </script>
    

