@{
    ViewBag.Title = "Crear";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

#tbPedido{
    width:100%;
    border-collapse:separate;
    border-spacing:0 10px;
}

#tbPedido thead{
    display:none;
}

#tbPedido tbody tr{
    background:transparent !important;
}

#tbPedido tbody td{
    border:none !important;
    padding:0 !important;
}

/* CARD */

.pedido-card{
    background:#fff;
    border:1px solid #edf0f2;
    border-radius:16px;
    padding:14px;
    box-shadow:0 2px 8px rgba(0,0,0,.05);
    transition:.15s ease;
}

.pedido-card:hover{
    transform:translateY(-1px);
    box-shadow:0 4px 14px rgba(0,0,0,.08);
}

/* TOP */

.pedido-top{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:12px;
}

.pedido-producto{
    display:flex;
    gap:12px;
    align-items:center;
}

/* ICONO */

.pedido-icon{
    width:46px;
    height:46px;
    border-radius:14px;
    background:#f5f6f8;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:18px;
    color:#495057;
}

/* INFO */

.pedido-info{
    line-height:1.2;
}

.pedido-nombre{
    font-size:14px;
    font-weight:600;
    color:#212529;
}

.pedido-codigo{
    font-size:11px;
    color:#6c757d;
    margin-top:3px;
}

/* ELIMINAR */

.btn-eliminar{
    width:36px;
    height:36px;
    border-radius:12px !important;
}

/* LINEA INFERIOR */

.pedido-linea{
    margin-top:14px;
    display:flex;
    align-items:center;
    justify-content:flex-start;
    gap:18px;
    flex-wrap:wrap;
}

.pedido-mini{
    display:flex;
    align-items:center;
    gap:8px;
}

.pedido-mini-label{
    font-size:11px;
    color:#6c757d;
    font-weight:600;
}

/* INPUT */

.txtcantidad{
    width:70px !important;
    height:34px;
    text-align:center;
    border-radius:10px !important;
    font-weight:600;
}

/* PRECIO */

.pedido-precio{
    font-weight:600;
    color:#0d6efd;
    min-width:60px;
    font-size:14px;
}

/* TOTAL */

.pedido-total{
    font-weight:700;
    color:#198754;
    min-width:70px;
    font-size:15px;
}

/* MOBILE */

@@media(max-width:768px){

    .pedido-linea{
        gap:10px;
    }

    .pedido-top{
        align-items:flex-start;
    }

}

</style>

<style>

    .total-final-box {
        min-height: 38px;
        border-radius: 8px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        font-size: 1.4rem;
        font-weight: 700;
        padding: 0 12px;
    }

    .total-final-currency {
        font-size: 1rem;
        color: #28a745;
    }

    .total-final-text {
        color: #28a745;
    }

    @@media (max-width: 768px) {

        .total-final-box {
            font-size: 1.2rem;
        }

        #btnTerminarGuardarPedido {
            width: 100%;
        }
    }


/* =====================================
   SWITCH CARD MODERNO
===================================== */

.switch-card {

    display: flex;
    align-items: center;
    justify-content: space-between;

    gap: 15px;

    background: #fff;

    border: 1px solid #e9ecef;

    border-radius: 16px;

    padding: 14px 18px;

    box-shadow:
        0 2px 10px rgba(0,0,0,.05);

    transition: all .2s ease;
}

.switch-card:hover {

    border-color: #0d6efd;

    box-shadow:
        0 4px 16px rgba(13,110,253,.12);
}

.switch-info {

    display: flex;
    align-items: center;

    gap: 14px;

    min-width: 0;
}

.switch-icon {

    width: 42px;
    height: 42px;

    border-radius: 12px;

    background: rgba(13,110,253,.10);

    color: #0d6efd;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 18px;

    flex-shrink: 0;
}

.switch-title {

    font-size: 15px;
    font-weight: 700;

    color: #212529;

    line-height: 1.2;
}

.switch-subtitle {

    font-size: 13px;

    color: #6c757d;

    margin-top: 2px;
}

.switch-container {

    margin: 0 !important;

    display: flex;
    align-items: center;
    justify-content: center;
}

.switch-container .form-check-input {

    width: 3rem;
    height: 1.5rem;

    cursor: pointer;
}

/* =====================================
   MOBILE
===================================== */

@@media (max-width: 576px) {

    .switch-card {

        padding: 12px 14px;
    }

    .switch-title {

        font-size: 14px;
    }

    .switch-subtitle {

        font-size: 12px;
    }

    .switch-icon {

        width: 38px;
        height: 38px;

        font-size: 16px;
    }
}

/* BOTON SELECCIONAR */

#tbProducto .btn-primary {

    width: 34px;
    height: 34px;

    border-radius: 12px;

    display: flex;
    align-items: center;
    justify-content: center;

    padding: 0;
}

/* MOBILE */

@@media (max-width: 768px) {

    .switch-precio-container {

        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
}
</style>

<style>

	#tbProducto tbody tr {
		background: transparent !important;
		border: 0 !important;
	}

	.producto-card {
		border: 1px solid #e9ecef;
		border-radius: 14px;
		padding: 10px 12px;
		margin-bottom: 10px;
		background: #fff;
		transition: all .15s ease;
		box-shadow: 0 2px 6px rgba(0,0,0,.04);
	}

		.producto-card:hover {
			transform: translateY(-1px);
			box-shadow: 0 4px 10px rgba(0,0,0,.08);
		}

	.producto-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 10px;
	}

	.producto-nombre {
		font-weight: 600;
		font-size: 14px;
		color: #212529;
		line-height: 1.2;
	}

	.producto-codigo {
		font-size: 11px;
		color: #6c757d;
		margin-top: 2px;
	}

	.producto-detalle {
		display: flex;
		justify-content: space-between;
		margin-top: 8px;
	}

	.producto-item {
		text-align: center;
		flex: 1;
	}

	.producto-label {
		font-size: 10px;
		color: #6c757d;
		text-transform: uppercase;
	}

	.producto-value {
		font-size: 13px;
		font-weight: 600;
		color: #212529;
	}

	.btn-producto {
		border-radius: 10px !important;
		padding: 6px 10px !important;
	}

	#tbProducto td {
		border-top: 0 !important;
		padding: 4px !important;
		background: transparent !important;
	}

	.dataTables_wrapper .dataTables_paginate .paginate_button {
		padding: 0 !important;
		margin-left: 2px;
	}

	.producto-seleccionado {
		border: 1px solid #28a745;
		background: #f4fff7;
		opacity: .9;
	}
</style>

<style>
	.custom-switch-sm .custom-control-label::before {
		width: 2rem;
		height: 1rem;
		border-radius: 20px;
		top: .20rem;
	}

	.custom-switch-sm .custom-control-label::after {
		width: .75rem;
		height: .75rem;
		border-radius: 50%;
		top: calc(.20rem + 2px);
		left: calc(-2rem + 2px);
	}

	.custom-switch-sm
	.custom-control-input:checked ~ .custom-control-label::after {
		transform: translateX(.9rem);
	}
</style>

<div class="row">
    <div class="col-sm-12">

        <div class="card border-secondary">

            <div class="card-header p-2 bg-secondary text-white d-flex justify-content-between align-items-center">

                <span>Crear Pedido</span>

            </div>

            <div class="card-body p-2 card-pedido">

                <!-- CABECERA -->
                <div class="row">

                    <div class="col-sm-3">

                        <div class="input-group input-group-sm mb-2">

                            <div class="input-group-prepend">
                                <label class="input-group-text bg-secondary text-white">
                                    Tipo Documento
                                </label>
                            </div>

                            <select class="custom-select"
                                    id="cboPedidotipodocumento">

                                <option value="Pedido" selected>
                                    Pedido
                                </option>

                            </select>

                        </div>

                    </div>

                    <div class="col-sm-3">

                        <div class="input-group input-group-sm mb-2">

                            <div class="input-group-prepend">
                                <label class="input-group-text bg-secondary text-white">
                                    Fecha de Pedido
                                </label>
                            </div>

                            <input id="txtfechaPedido"
                                   readonly
                                   type="text"
                                   class="form-control">

                        </div>

                    </div>

                    <div class="col-sm-3">

                        <div class="input-group input-group-sm mb-2">

                            <div class="input-group-prepend">
                                <label class="input-group-text bg-secondary text-white">
                                    Fecha de Entrega
                                </label>
                            </div>

                            <input id="txtfechaEntrega"
                                   type="text"
                                   class="form-control form-control-sm model">

                        </div>

                    </div>

                   <div class="col-sm-3">

                       <div class="input-group input-group-sm mb-2">

                           <div class="input-group-prepend">
                               <label class="input-group-text bg-secondary text-white">
                                   Pedido Pagado
                               </label>
                           </div>

                           <div class="form-control d-flex align-items-center justify-content-center">

                               <small class="text-muted mr-2">
                                   Sí / No
                               </small>

                               <div class="custom-control custom-switch custom-switch-sm m-0">

                                   <input type="checkbox"
                                          class="custom-control-input"
                                          id="chkEstadoPago">

                                   <label class="custom-control-label"
                                          for="chkEstadoPago"></label>

                               </div>

                           </div>

                       </div>

                   </div>

                </div>

                <!-- TIENDA / EMPLEADO -->
                <div class="row d-none">

                    <!-- TIENDA -->
                    <div class="col-sm-6">

                        <div class="card bg-secondary text-white border-secondary">

                            <div class="card-body p-2">

                                <div class="row">

                                    <div class="col-sm-10">
                                        <h6 class="card-title mb-1">
                                            Tienda origen
                                        </h6>
                                    </div>

                                    <div class="col-sm-2">

                                        <div class="float-right">

                                            <a class="btn btn-light btn-sm"
                                               data-toggle="collapse"
                                               href="#collapse1">

                                                <i class="fa fa-bars"></i>

                                            </a>

                                        </div>

                                    </div>

                                </div>

                                <div class="row collapse"
                                     id="collapse1">

                                    <input id="txtIdTienda"
                                           type="hidden"
                                           value="0" />

                                    <div class="col-sm-4">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Nombre:
                                            </label>

                                            <label class="form-control form-control-sm model mb-1"
                                                   readonly
                                                   id="lbltiendanombre"></label>

                                        </div>

                                    </div>

                                    <div class="col-sm-4">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                RUC:
                                            </label>

                                            <label class="form-control form-control-sm model mb-1"
                                                   readonly
                                                   id="lbltiendaruc"></label>

                                        </div>

                                    </div>

                                    <div class="col-sm-4">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Direccion:
                                            </label>

                                            <label class="form-control form-control-sm model mb-1"
                                                   readonly
                                                   id="lbltiendadireccion"></label>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- EMPLEADO -->
                    <div class="col-sm-6">

                        <div class="card bg-secondary text-white border-secondary">

                            <div class="card-body p-2">

                                <div class="row">

                                    <div class="col-sm-10">
                                        <h6 class="card-title mb-1">
                                            Datos Empleado
                                        </h6>
                                    </div>

                                    <div class="col-sm-2">

                                        <div class="float-right">

                                            <a class="btn btn-light btn-sm"
                                               data-toggle="collapse"
                                               href="#collapse2">

                                                <i class="fa fa-bars"></i>

                                            </a>

                                        </div>

                                    </div>

                                </div>

                                <div class="row collapse"
                                     id="collapse2">

                                    <input id="txtIdUsuario"
                                           type="hidden"
                                           value="0" />

                                    <div class="col-sm-4">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Nombre:
                                            </label>

                                            <label class="form-control form-control-sm model mb-1"
                                                   readonly
                                                   id="lblempleadonombre"></label>

                                        </div>

                                    </div>

                                    <div class="col-sm-4">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Apellido:
                                            </label>

                                            <label class="form-control form-control-sm model mb-1"
                                                   readonly
                                                   id="lblempleadoapellido"></label>

                                        </div>

                                    </div>

                                    <div class="col-sm-4">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Correo:
                                            </label>

                                            <label class="form-control form-control-sm model mb-1"
                                                   readonly
                                                   id="lblempleadocorreo"></label>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- CLIENTE / PRODUCTO -->
                <div class="row mt-2">

                    <!-- CLIENTE -->
                    <div class="col-sm-12">

                        <div class="card border-secondary">

                            <div class="card-body p-2">

                                <h6 class="text-secondary mb-3">
                                    <i class="fa fa-user mr-1"></i>
                                    Detalle cliente
                                </h6>

                                <div class="row align-items-end">

                                    <div class="col-sm-3">
                                        <label class="col-form-label col-form-label-sm">
                                            Documento:
                                            <span class="required">*</span>
                                        </label>
                                        <div class="input-group input-group-sm">
                                            <input type="text"
                                                   class="form-control model"
                                                   id="txtclientedocumento"
                                                   autocomplete="off"
                                                   readonly>

                                            <button type="button"
                                                    id="btnBuscarCliente"
                                                    class="btn btn-primary"
                                                    style="
                                                border-top-left-radius:0;
                                                border-bottom-left-radius:0;
                                                padding:0 10px;
                                                font-size:16px;
                                                line-height:1;
                                            ">
                                                <i class="fa fa-plus"></i>
                                            </button>

                                        </div>
                                    </div>

                                    <div class="col-sm-2 d-none">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Tipo :
                                            </label>

                                            <select class="form-control form-control-sm model"
                                                    id="cboclientetipodocumento" disabled>

                                                <option value="DNI">DNI</option>
                                                <option value="RUC">RUC</option>

                                            </select>

                                        </div>

                                    </div>

                                    <div class="col-sm-9">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Nombres:
                                                <span class="required">*</span>
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   id="txtclientenombres"
                                                   autocomplete="off"
                                                   readonly>

                                        </div>

                                    </div>

                                </div>

                                <div class="row mt-2 d-none">

                                    <div class="col-sm-6">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Direccion:
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   id="txtclientedireccion"
                                                   autocomplete="off">

                                        </div>

                                    </div>

                                    <div class="col-sm-6">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Telefono:
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   id="txtclientetelefono"
                                                   autocomplete="off">

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- PRODUCTO -->
                    <div class="col-sm-12">

                        <div class="card border-secondary">

                            <div class="card-body p-2">

                                <h6 class="text-secondary mb-3">
                                    <i class="fa fa-box mr-1"></i>
                                    Detalle Producto
                                </h6>

                                <div class="row align-items-end">

                                    <input id="txtIdProducto"
                                           type="hidden"
                                           value="0" />

                                    <div class="col-sm-3">

                                        <label class="col-form-label col-form-label-sm">
                                            Codigo:
                                            <span class="required">*</span>
                                        </label>

                                        <div class="input-group input-group-sm">

                                            <input type="text"
                                                   class="form-control model"
                                                   id="txtproductocodigo"
                                                   autocomplete="off">

                                            <button type="button"
                                                    id="btnBuscarProducto"
                                                    class="btn btn-primary"
                                                    style="
                                                    border-top-left-radius:0;
                                                    border-bottom-left-radius:0;
                                                    padding:0 10px;
                                                    font-size:16px;
                                                    line-height:1;
                                                ">
                                                <i class="fa fa-search"></i>
                                            </button>

                                        </div>

                                    </div>

                                    <div class="col-sm-9">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Nombre:
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   readonly
                                                   id="txtproductonombre">

                                        </div>

                                    </div>

                                    <div class="col-sm-6 d-none">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Descripcion:
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   readonly
                                                   id="txtproductodescripcion">

                                        </div>

                                    </div>

                                </div>

                                <div class="row mt-2">
                                    <div class="col-sm-1 d-none">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                En Stock:
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   readonly
                                                   id="txtproductostock">

                                        </div>

                                    </div>

                                    <div class="col-sm-1 d-none">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Precio:
                                            </label>

                                            <input type="text"
                                                   class="form-control form-control-sm model"
                                                   readonly
                                                   id="txtproductoprecio">

                                        </div>

                                    </div>

                                    <div class="col-sm-3">

                                        <div class="form-group mb-0">

                                            <label class="col-form-label col-form-label-sm">
                                                Cantidad:
                                                <span class="required">*</span>
                                            </label>

                                            <input type="number"
                                                   class="form-control form-control-sm model"
                                                   id="txtproductocantidad"
                                                   autocomplete="off"
                                                   min="1"
                                                   value="1">

                                        </div>

                                    </div>

                                    <div class="col-sm-9">

                                        <div class="form-group mb-0">

                                            <label class="invisible">
                                                agregar
                                            </label>

                                            <button id="btnAgregar"
                                                    type="button"
                                                    class="btn btn-info btn-sm btn-block">

                                                <i class="fa fa-plus"></i>
                                                Agregar

                                            </button>

                                        </div>

                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

                <!-- TABLA -->
                <hr />

                <div class="row">
                    <div class="col-sm-12">
                        <h6 class="text-secondary">
                            Detalle Productos
                        </h6>
                    </div>
                </div>

                <div class="row mt-3">

                    <div class="col-sm-12">

                        <div class="table-responsive-sm">

                            <table id="tbPedido"
                                   class="table table-striped table-bordered nowrap table-sm"
                                   style="width:100%">

                                <thead>
                                    <tr>
                                        <th></th>
                                        <th>Cantidad</th>
                                        <th>Producto</th>
                                        @*<th>Descripcion</th>*@
                                        <th>Precio</th>
                                        <th>Importe Total</th>
                                    </tr>
                                </thead>

                                <tbody></tbody>

                            </table>

                        </div>

                    </div>

                </div>

                <!-- TOTALES -->

                <hr />

                <!-- =========================
            TOTALES RESPONSIVE SIMPLE
        ========================= -->

                <hr />

                <div class="card shadow-sm border-0 mb-3">
                    <div class="card-body py-3">
                        <div class="row align-items-end justify-content-end g-2">

                            <!-- % DESCUENTO -->
                            <div class="col-xl-2 col-lg-3 col-md-4 col-6">

                                <label class="font-weight-bold text-muted small mb-1 d-block">
                                    % DESCUENTO
                                </label>

                                <div class="input-group input-group-sm">

                                    <input id="txtdescuentoporcentaje"
                                           type="number"
                                           min="0"
                                           max="100"
                                           value="0"
                                           class="form-control text-center">

                                    <div class="input-group-append">
                                        <span class="input-group-text">%</span>
                                    </div>

                                </div>

                            </div>

                            <!-- DESCUENTO -->
                            <div class="col-xl-2 col-lg-3 col-md-4 col-6">

                                <label class="font-weight-bold text-muted small mb-1 d-block">
                                    DESCUENTO
                                </label>

                                <div class="input-group input-group-sm">

                                    <div class="input-group-prepend">
