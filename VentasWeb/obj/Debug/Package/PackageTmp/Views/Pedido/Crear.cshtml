@section scripts{
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script>

        // =========================================
        // RECALCULAR TOTALES
        // =========================================

        function recalcularTotalesPedido() {

            let subtotal = 0;

            $("#tbPedido tbody tr").each(function () {

                let importe = parseFloat(
                    $(this).find(".importetotal").text()
                ) || 0;

                subtotal += importe;

            });

            let porcentaje =
                parseFloat($("#txtdescuentoporcentaje").val()) || 0;

            let descuento = (subtotal * porcentaje) / 100;

            let totalFinal = subtotal - descuento;

            $("#txttotal").val(totalFinal.toFixed(2));

            $("#txtdescuentoimporte")
                .val(descuento.toFixed(2));

            $("#lbltotal")
                .text(totalFinal.toFixed(2));

        }

        // =========================================
        // AL CAMBIAR DESCUENTO
        // =========================================

        $(document).on("keyup change",
            "#txtdescuentoporcentaje",
            function () {

                recalcularTotalesPedido();

            });

        // =========================================
        // AL AGREGAR PRODUCTO
        // =========================================

        $(document).on("click",
            "#btnAgregar",
            function () {

                // ESPERAR QUE EL JS ORIGINAL TERMINE
                setTimeout(function () {

                    recalcularTotalesPedido();

                }, 200);

            });

        // =========================================
        // AL ELIMINAR PRODUCTO
        // =========================================

        //$(document).on("click",
        //    ".btn-eliminar",
        //    function () {
        //        setTimeout(function () {
        //            recalcularTotalesPedido();
        //        }, 200);
        //    });
        $(document).on("click", ".btn-eliminar", function () {

            let fila = $(this).closest("tr");

            // OBTENER ID PRODUCTO
            let idproducto = fila
                .find(".producto")
                .data("idproducto");

            // QUITAR DEL ARRAY
            productosSeleccionados = productosSeleccionados.filter(x =>
                x != idproducto
            );

            // ELIMINAR FILA
            fila.remove();

            // RECALCULAR
            recalcularTotalesPedido();

            // RECARGAR CATÁLOGO
            tablaproducto.ajax.reload(null, false);

        });

        // =========================================
        // INICIAL
        // =========================================

        $(document).ready(function () {

            recalcularTotalesPedido();

        });

        // =========================================
        // eliminar producto
        // =========================================

        $(document).on("click", ".btn-eliminar", function () {

            $(this).closest("tr").remove();

            recalcularTotalesPedido();

        });

        // =========================================
        // actualiza cantidad
        // =========================================

        $(document).on("input", ".txtcantidad", function () {

            let fila = $(this).closest("tr");

            let cantidad = parseFloat($(this).val()) || 0;

            let precio = parseFloat(
                fila.find(".productoprecio").data("precio")
            ) || 0;

            let nuevoImporte = cantidad * precio;

            fila.find(".importetotal")
                .text(nuevoImporte.toFixed(2));

            recalcularTotalesPedido();

        });

    </script>

    <script src="@Url.Content("~/Scripts/Views/Pedido_Crear.js")"
            type="text/javascript"></script>

}