
@{
    ViewBag.Title = "ConsultarMobil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .badge-pendiente {
        background: #fff3cd;
        color: #856404;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-facturado {
        background: #d1ecf1;
        color: #0c5460;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-entregado {
        background: #d4edda;
        color: #155724;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

    .badge-anulado {
        background: #f8d7da;
        color: #721c24;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
    }

	#contenedorVentas .pedido-card {
		border: none;
		border-radius: 14px;
		background: #fff;
		box-shadow: 0 2px 10px rgba(0,0,0,.05);
		transition: .2s ease;
	}

		#contenedorVentas .pedido-card:hover {
			transform: translateY(-2px);
			box-shadow: 0 5px 16px rgba(0,0,0,.08);
		}

	#contenedorVentas .pedido-codigo {
		font-size: 15px;
		font-weight: 700;
		color: #212529;
		line-height: 1.2;
	}

	#contenedorVentas .pedido-fecha {
		font-size: 11px;
		color: #8c8c8c;
		margin-top: 2px;
	}

	#contenedorVentas .pedido-estado {
		padding: 4px 10px;
		border-radius: 20px;
		font-size: 10px;
		font-weight: 600;
	}

	#contenedorVentas .estado-pendiente {
		background: #fff3cd;
		color: #856404;
	}

	#contenedorVentas .estado-facturado {
		background: #dbeafe;
		color: #1e40af;
	}

	#contenedorVentas .estado-entregado {
		background: #dcfce7;
		color: #166534;
	}

	#contenedorVentas .estado-anulado {
		background: #fee2e2;
		color: #991b1b;
	}

	#contenedorVentas .cliente-nombre {
		font-size: 14px;
		font-weight: 600;
		color: #212529;
		line-height: 1.2;
	}

	#contenedorVentas .cliente-documento {
		font-size: 12px;
		color: #6c757d;
		margin-top: 2px;
	}

	#contenedorVentas .pedido-label {
		font-size: 10px;
		color: #8c8c8c;
		text-transform: uppercase;
	}

	#contenedorVentas .pedido-total {
		font-size: 20px;
		font-weight: 700;
		color: #16a34a;
		line-height: 1;
	}

	#contenedorVentas .btn-detalle {
		border-radius: 10px;
		padding: 6px 14px;
		font-size: 12px;
		font-weight: 600;
		background: #f8f9fa;
		border: 1px solid #e5e7eb;
		color: #374151;
	}

		#contenedorVentas .btn-detalle:hover {
			background: #eef2f7;
		}
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb" class="mb-0">
        <ol class="breadcrumb mb-0 bg-transparent p-0">
            <li class="breadcrumb-item">
                <a href="#">GESTION DE PEDIDO</a>
            </li>
        </ol>
    </nav>

    <button type="button"
            class="btn btn-sm btn-outline-primary"
            onclick="nuevoPedido()">
        <i class="fas fa-plus"></i> Nuevo
    </button>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="card">
            <div class="card-body p-2">

                <div class="mb-3" id="accordion">
                    <div class="card border-secondary">
                        <div class="card-header p-2 bg-secondary text-white" id="headingOne">
                            Filtros
                            <button class="btn btn-light btn-sm float-right" data-toggle="collapse" data-target="#collapseOne" aria-controls="collapseOne">
                                <i class="fa fa-bars" aria-hidden="true"></i>
                            </button>
                        </div>
                        <div id="collapseOne" class="collapse" aria-labelledby="headingOne" data-parent="#accordion">
                            <div class="row">
                                <div class="col-sm-2">
                                    <div class="form-group mb-0">
                                        <label for="txtRucProveedor" class="col-form-label col-form-label-sm">Fecha Inicio:</label>
                                        <input type="text" class="form-control form-control-sm model" id="txtFechaInicio" name="FechaInicio" autocomplete="off">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group mb-0">
                                        <label for="txtRucProveedor" class="col-form-label col-form-label-sm">Fecha Fin:</label>
                                        <input type="text" class="form-control form-control-sm model" id="txtFechaFin" name="FechaFin" autocomplete="off">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group mb-0">
                                        <label for="txtRucProveedor" class="col-form-label col-form-label-sm">Codigo Pedido:</label>
                                        <input type="text" class="form-control form-control-sm model" id="txtCodigoVenta" name="FechaInicio" autocomplete="off">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group mb-0">
                                        <label for="txtRucProveedor" class="col-form-label col-form-label-sm">Documento Cliente:</label>
                                        <input type="text" class="form-control form-control-sm model" id="txtDocumentoCliente" name="FechaInicio" autocomplete="off">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group mb-0">
                                        <label for="txtRucProveedor" class="col-form-label col-form-label-sm">Nombre Cliente:</label>
                                        <input type="text" class="form-control form-control-sm model" id="txtNombreCliente" name="FechaInicio" autocomplete="off">
                                    </div>
                                </div>
                                <div class="col-sm-2">
                                    <div class="form-group mb-0">
                                        <label for="btnBuscar" class="col-form-label col-form-label-sm invisible">Direccion:</label>
                                        <button id="btnBuscar" type="button" class="btn btn-sm btn-primary btn-block" onclick="buscar()">Buscar</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="row mt-3">
                    <div class="col-sm-12">

                     <div class="row" id="contenedorVentas"></div>

                        @*<table id="tbVentas" class="table table-striped table-bordered nowrap compact" style="width:100%">
                            <thead>
                                <tr>
                                    <th>Documento</th>
                                    <th>Estado</th>
                                    <th>Cliente</th>
                                    <th>Doc. Cliente</th>
                                    <th>Fecha</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>*@
                    </div>
                </div>
            </div>
            <div class="card-footer">
            </div>
        </div>
    </div>
</div>

<!-- MODAL GENERAR VENTA -->
<div class="modal fade" id="modalGenerarVenta" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    Generar Venta
                </h5>
                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdPedidoVenta" />

                <!-- RESUMEN -->
                <div class="card border-0 shadow-sm mb-3">

                    <div class="card-header bg-light">
                        <strong>Resumen del Pedido</strong>
                    </div>

                    <div class="card-body p-3">

                        <div class="row">

                            <div class="col-6 mb-2">
                                <small class="text-muted">Tipo Documento</small>
                                <div id="lblTipoDocumento" class="font-weight-bold">
                                    BOLETA
                                </div>
                            </div>

                            <div class="col-6 mb-2">
                                <small class="text-muted">Código</small>
                                <div id="lblCodigoPedido" class="font-weight-bold">
                                    -
                                </div>
                            </div>

                            <div class="col-12 mb-2">
                                <small class="text-muted">Cliente</small>
                                <div id="lblClientePedido" class="font-weight-bold">
                                    -
                                </div>
                            </div>

                            <div class="col-6 mb-2">
                                <small class="text-muted">Subtotal</small>
                                <div id="lblSubtotalPedido" class="font-weight-bold text-dark">
                                    S./ 0.00
                                </div>
                            </div>

                            <div class="col-6 mb-2">
                                <small class="text-muted">Descuento</small>
                                <div id="lblDescuentoPedido" class="font-weight-bold text-danger">
                                    S./ 0.00
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="resumen-total-box mt-2">

                                    <small>TOTAL PEDIDO</small>

                                    <h3 id="lblTotalPedido">
                                        S./ 0.00
                                    </h3>

                                </div>
                            </div>

                        </div>

                    </div>

                </div>

                <!-- CONFIGURACION -->
                <div class="form-group">
                    <label>Documento Venta</label>
                    <select id="cboTipoDocumentoVenta" class="form-control form-control-sm">
                        <option value="Nota de Venta" selected>Nota de Venta</option>
                        <option value="Boleta">Boleta</option>
                        <option value="Factura">Factura</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Método Pago</label>
                    <select id="cboMetodoPago" class="form-control form-control-sm">
                        <option value="EFECTIVO" selected>EFECTIVO</option>
                        <option value="TARJETA">TARJETA</option>
                        <option value="YAPE">YAPE</option>
                        <option value="PLIN">PLIN</option>
                        <option value="TRANSFERENCIA">TRANSFERENCIA</option>
                        <option value="OTROS">OTROS</option>
                    </select>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn btn-danger btn-sm" data-dismiss="modal">
                    Cancelar
                </button>

                <button class="btn btn-primary btn-sm" onclick="GenerarVentaPedido()">
                    Confirmar Venta
                </button>
            </div>

        </div>
    </div>
</div>

@section scripts{

<script src="@Url.Content("~/Scripts/Views/Pedido_ConsultarMobil.js")" type="text/javascript"></script>
}

