@section scripts{
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script>

        // =========================================
        // RECALCULAR TOTALES
        // =========================================

        function recalcularTotalesPedido() {

            let subtotal = 0;

            $("#tbPedido tbody tr").each(function () {

                let fila = $(this);

                let importeTexto = fila
                    .find(".importetotal")
                    .text()
                    .trim();

                importeTexto = importeTexto
                    .replace("S/", "")
                    .replace(",", "");

                let importe = parseFloat(importeTexto) || 0;

                subtotal += importe;

            });

            // DESCUENTO %
            let porcentaje =
                parseFloat($("#txtdescuentoporcentaje").val()) || 0;

            // IMPORTE DESCUENTO
            let descuento = (subtotal * porcentaje) / 100;

            // TOTAL FINAL
            let totalFinal = subtotal - descuento;

            // INPUTS
            $("#txttotal").val(totalFinal.toFixed(2));
            $("#txtdescuentoimporte").val(descuento.toFixed(2));

            // LABELS
            $("#lbltotal").text(totalFinal.toFixed(2));

        }

        // =========================================
        // AL CAMBIAR DESCUENTO
        // =========================================

        $(document).on("keyup change",
            "#txtdescuentoporcentaje",
            function () {

                recalcularTotalesPedido();

            });

        // =========================================
        // AL AGREGAR PRODUCTO
        // =========================================

        $(document).on("click",
            "#btnAgregar",
            function () {

                // ESPERAR QUE EL JS ORIGINAL TERMINE
                setTimeout(function () {

                    recalcularTotalesPedido();

                }, 200);

            });

        // =========================================
        // AL ELIMINAR PRODUCTO
        // =========================================

        $(document).on("click",
            ".btn-eliminar",
            function () {

                setTimeout(function () {

                    recalcularTotalesPedido();

                }, 200);

            });

        // =========================================
        // INICIAL
        // =========================================

        $(document).ready(function () {

            recalcularTotalesPedido();

        });

        // =========================================
        // eliminar producto
        // =========================================

        $(document).on("click", ".btn-eliminar", function () {

            $(this).closest("tr").remove();

            recalcularTotalesPedido();

        });

        // =========================================
        // actualiza cantidad
        // =========================================
        $(document).on("input", ".txtcantidad", function () {

            var fila = $(this).closest("tr");

            var cantidad = parseFloat($(this).val()) || 0;

            var precio = parseFloat(
                fila.find(".productoprecio").text()
            ) || 0;

            var nuevoImporte = cantidad * precio;

            fila.find(".importetotal")
                .text(nuevoImporte.toFixed(2));

            recalcularTotalesPedido();

        });

    </script>

    <script src="@Url.Content("~/Scripts/Views/Pedido_Crear.js")"
            type="text/javascript"></script>

}