
@{
    ViewBag.Title = "Catalogo";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row">
    <div class="col-sm-12">

        <div class="card border-secondary">
            <div class="card-header bg-secondary text-white p-2">
                Productos >> Catálogo de productos
            </div>
            <div id="card-lista" class="card-body p-3">
                <div class="row">
                    <div class="col-sm-12">
                        <div class="table-responsive">
                            <table id="tbdata" class="table table-striped table-bordered nowrap compact" style="width:100%">
                                <thead>
                                    <tr>
                                        <th>Tienda</th>
                                        <th>Codigo Producto</th>
                                        <th>Nombre Producto</th>
                                        <th>Stock</th>
                                        <th>Precio Catálogo</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalEditarPrecio" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-md" role="document">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">
                    Actualizar Precio Catálogo
                </h5>

                <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="txtIdProductoTienda" />
                <div class="form-group">
                    <label>Producto</label>
                    <input type="text"
                           class="form-control"
                           id="txtNombreProducto"
                           readonly>
                </div>
                <div class="form-group mb-0">
                    <label>Precio Catálogo</label>

                    <input type="number"
                           class="form-control"
                           id="txtPrecioPaqueteVenta"
                           step="0.01">
                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-secondary btn-sm"
                        data-dismiss="modal">
                    Cancelar
                </button>

                <button class="btn btn-info btn-sm"
                        onclick="GuardarPrecio()">
                    Guardar
                </button>

            </div>

        </div>
    </div>
</div>

@section scripts{

    <script src="@Url.Content("~/Scripts/Views/Producto_Catalogo.js")" type="text/javascript"></script>
}

